# Copy to .env and fill in your values.

GITHUB_TOKEN=ghp_your_token_here
GITHUB_USER=aimoptheman
POLL_INTERVAL=60
COOLDOWN=300

# ── Pick ONE trigger mode ──────────────────────────────────────────────────────

# CLI / Docker mode: paste the docker run command you use to start OpenHands,
# then add the -t flag at the end pointing at "run workflow".
# Example (fill in your actual image tag and API key):
#
# TRIGGER_CMD=docker run --rm #   -e SANDBOX_RUNTIME_CONTAINER_IMAGE=docker.all-hands.dev/all-hands-ai/runtime:0.39-nikolaik #   -e LLM_MODEL=anthropic/claude-sonnet-4-20250514 #   -e LLM_API_KEY=sk-ant-... #   -e GITHUB_TOKEN=ghp_... #   -v /var/run/docker.sock:/var/run/docker.sock #   -v ~/.openhands-state:/.openhands-state #   docker.all-hands.dev/all-hands-ai/openhands:0.39 #   python -m openhands.core.main -t "run workflow" --no-auto-continue

# Server / GUI mode: uncomment if running OpenHands with -p 3000:3000
# OPENHANDS_URL=http://localhost:3000
